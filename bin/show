#!/usr/bin/env bash
# show: open file(s) in the user's default macOS app for display.
# Source: Meta/blank/bin/show — symlinked to ~/.local/bin/show
# Usage: show <file> [file...]
#   - Relative paths resolve against current pwd
#   - ~ expansion supported
#   - Errors with exit 1 if any path does not exist
#
# Routing:
#   - .md / .markdown / .txt → CotEditor (regardless of system default)
#   - everything else → macOS default app via `open`
#
# Desktop targeting: the caller's Desktop space_id is resolved BEFORE opening the file
# (detect-before-disturb), then the new window is moved there after open. Best-effort —
# file still opens on whichever Desktop is active if resolution fails.
# Both resolution and move outcomes are logged to ~/Library/Logs/blank/desktop_targeting.log.

set -e

_SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
_DESKTOP_HELPER="$_SCRIPT_DIR/../src/desktop/desktop_targeting.py"

if [ $# -lt 1 ]; then
  echo "Usage: show <file> [file...]" >&2
  exit 1
fi

# Resolve caller's Desktop space_id ONCE before iterating files (caller context is constant).
# $PPID = parent of this bash subprocess = the chat-Bash that invoked show.
_space_id=""
if [ -f "$_DESKTOP_HELPER" ]; then
  _space_id=$(python3 "$_DESKTOP_HELPER" find-caller-desktop "$PPID" show 2>/dev/null | cut -d' ' -f1)
fi

for f in "$@"; do
  # ~ expansion
  f="${f/#\~/$HOME}"
  # relative → absolute (anchored at pwd)
  [[ "$f" != /* ]] && f="$(pwd)/$f"
  if [ ! -e "$f" ]; then
    echo "show: not found: $f" >&2
    exit 1
  fi

  # Extension-based routing (text formats → CotEditor)
  ext_lower="$(echo "${f##*.}" | tr '[:upper:]' '[:lower:]')"
  case "$ext_lower" in
    md|markdown|txt)
      open -a "CotEditor" "$f"
      app_name="CotEditor"
      ;;
    *)
      open "$f"
      app_name=""   # unknown handler → helper polls across all apps
      ;;
  esac

  # Move new window to pre-resolved Desktop. Background to avoid blocking.
  # Logs move result to ~/Library/Logs/blank/desktop_targeting.log.
  if [ -n "$_space_id" ] && [ -f "$_DESKTOP_HELPER" ]; then
    python3 "$_DESKTOP_HELPER" wait-and-move-space "$_space_id" "$app_name" 4 show &
  fi

  echo "opened: $f"
done
