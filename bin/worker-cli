#!/usr/bin/env bash
# worker-cli: worker lifecycle operations via iterative-dev plugin
# Source: Meta/blank/bin/worker-cli — symlinked to ~/.local/bin/worker-cli

set -e

PLUGIN="${CLAUDE_PLUGIN_ROOT:-$HOME/.claude/plugins/cache/brunowinter-plugins/iterative-dev/1.0.0}"
SPAWN="$PLUGIN/src/spawn/tmux_spawn.sh"
REGISTRY_DIR="$HOME/.claude/.worker-registry"

usage() {
    cat <<'EOF'
usage: worker-cli <cmd> [args]

  list [project_path]                                        — list active workers (all if no path)
  status <name>                                              — idle / working / exited + context remaining %
  status --all [project_path]                                — snapshot all workers in one call
  capture <name>                                             — write pane to file, print path
  response <name> [N]                                        — clean last N assistant turns from session JSONL (default 1)
  merge <name>                                               — log + merge branch into current
  kill <name>                                                — tmux + worktree + branch cleanup
  send <name> <message>                                      — send message to running worker
  spawn <name> <prompt_file> <project_path> [model] [--no-worktree]
                                                             — spawn worker in git worktree

model: sonnet (default) | opus
Worker names are globally unique (registry-tracked). Project path is required only for spawn;
other commands auto-resolve via the registry.
Project path: absolute, ~/, or 'c' (resolves to current git project root, worktree-aware).
  'c' works from any directory: project root, subdirectory, or inside a worktree.
EOF
}

# Resolve project path — accepts absolute path, relative path, or 'c' / '.' / empty.
# Strips /.claude/worktrees/<name> suffix if present, then walks up to nearest .git root.
# NOTE: stops at first .git found — does not traverse into submodules.
resolve_project_path() {
    local dir="${1:-$(pwd)}"
    case "$dir" in c|.|'') dir="$(pwd)" ;; esac
    # Relative path → make absolute
    [[ "$dir" != /* ]] && dir="$(pwd)/$dir"
    # Strip worktree suffix to land at project root directly
    if [[ "$dir" == */.claude/worktrees/* ]]; then
        dir="${dir%%/.claude/worktrees/*}"
    fi
    # Walk up to nearest .git (covers both git dirs and worktree .git files)
    local d="$dir"
    while [[ "$d" != "/" && -n "$d" ]]; do
        [[ -e "$d/.git" ]] && { echo "$d"; return 0; }
        d="$(dirname "$d")"
    done
    echo "$dir"
}

# --- Registry helpers ---

registry_write() {
    local name="$1" project="$2"
    mkdir -p "$REGISTRY_DIR"
    echo "$project" > "$REGISTRY_DIR/$name"
}

registry_read() {
    local name="$1"
    local f="$REGISTRY_DIR/$name"
    [ -f "$f" ] && cat "$f" || echo ""
}

registry_delete() {
    local name="$1"
    rm -f "$REGISTRY_DIR/$name"
}

# Tmux scan fallback: derive project_path from session name pattern worker-<basename>-<name>.
# Searches ~/Documents/ai/ (3 levels deep) for dir named <basename> containing .git.
# Writes result to registry and returns it. Returns 1 if not found.
tmux_scan_project() {
    local name="$1"
    local count
    count=$(tmux ls 2>/dev/null | grep -cE "^worker-[^:]+-${name}:" || echo 0)
    if [ "$count" -eq 0 ]; then
        return 1
    fi
    if [ "$count" -gt 1 ]; then
        echo "worker-cli: multiple tmux sessions match worker name '$name':" >&2
        tmux ls 2>/dev/null | grep -oE "^worker-[^:]*-${name}[^:]*" >&2
        return 1
    fi
    local session
    session=$(tmux ls 2>/dev/null | grep -oE "^worker-[^:]*-${name}:" | head -1)
    session="${session%:}"
    # Extract basename: strip "worker-" prefix and "-<name>" suffix
    local middle="${session#worker-}"
    local proj_basename="${middle%-${name}}"
    # Scan ~/Documents/ai/ up to 6 levels for dir named proj_basename containing .git
    local found=""
    while IFS= read -r d; do
        if [ -e "$d/.git" ]; then
            found="$d"
            break
        fi
    done < <(find ~/Documents/ai -maxdepth 6 -type d -name "$proj_basename" 2>/dev/null)
    if [ -n "$found" ]; then
        registry_write "$name" "$found"
        echo "$found"
        return 0
    fi
    return 1
}

# Resolve project path for a named worker.
# Resolution order: explicit override → registry → tmux scan fallback → error.
# If override is non-empty, treat it as the project_path (backwards compat).
resolve_worker_project() {
    local name="$1"
    local override="${2:-}"
    if [ -n "$override" ]; then
        resolve_project_path "$override"
        return 0
    fi
    local from_registry
    from_registry=$(registry_read "$name")
    if [ -n "$from_registry" ]; then
        echo "$from_registry"
        return 0
    fi
    local from_tmux
    from_tmux=$(tmux_scan_project "$name" 2>&1) || true
    if [ -n "$from_tmux" ] && [[ "$from_tmux" != *"worker-cli:"* ]]; then
        echo "$from_tmux"
        return 0
    fi
    echo "worker-cli: worker '$name' not found in registry or tmux" >&2
    exit 1
}

# Encode an absolute path to the ~/.claude/projects/ dir name: replace /, ., _ with -.
encode_worktree_path() {
    local p="$1"
    p="${p//\//-}"; p="${p//\./-}"; p="${p//_/-}"
    echo "$p"
}

# Print context-remaining % for a worker based on its latest session JSONL.
# Returns "—%" if project is empty or no usage data found; never fails with non-zero exit.
context_pct() {
    local name="$1" project="$2"
    if [ -z "$project" ]; then echo "—%"; return; fi
    local worktree="$project/.claude/worktrees/$name"
    local encoded_dir="$HOME/.claude/projects/$(encode_worktree_path "$worktree")"
    local jsonl cr
    jsonl=$(ls -t "$encoded_dir"/*.jsonl 2>/dev/null | head -1)
    [ -z "$jsonl" ] && { echo "—%"; return; }
    cr=$(jq -rs '[.[] | select(.message.usage.cache_read_input_tokens? != null)] | last | .message.usage.cache_read_input_tokens // empty' "$jsonl" 2>/dev/null || true)
    if [ -z "$cr" ] || [ "$cr" = "null" ]; then
        echo "—%"
    else
        echo "$(( 100 * (200000 - cr) / 200000 ))%"
    fi
}

if [ $# -eq 0 ]; then
    usage
    exit 2
fi

CMD="$1"
shift

case "$CMD" in
    list)
        if [ $# -eq 0 ]; then
            # No project_path — list all known workers from registry
            if [ ! -d "$REGISTRY_DIR" ] || [ -z "$(ls -A "$REGISTRY_DIR" 2>/dev/null)" ]; then
                echo "(no known workers in registry)"
            else
                for _f in "$REGISTRY_DIR"/*; do
                    [ -f "$_f" ] || continue
                    _wname=$(basename "$_f")
                    _proj=$(cat "$_f")
                    _status=$(bash -c "source \"$SPAWN\" && worker_status \"\$1\" \"\$2\"" \
                        _ "$_wname" "$_proj" 2>/dev/null || echo "unknown")
                    _pct=$(context_pct "$_wname" "$_proj")
                    echo "${_wname}: ${_status} ${_pct}  (${_proj})"
                done
            fi
        else
            PROJECT=$(resolve_project_path "$1")
            bash -c "source \"$SPAWN\" && worker_list \"\$1\"" _ "$PROJECT"
        fi
        ;;
    status)
        if [ "${1:-}" = "--all" ]; then
            shift
            if [ $# -ge 1 ]; then
                # Project-scoped
                PROJECT=$(resolve_project_path "$1")
                NAMES=$(bash -c "source \"$SPAWN\" && worker_list \"\$1\"" _ "$PROJECT" 2>/dev/null \
                    | awk '{print $1}')
                if [ -z "$NAMES" ]; then
                    echo "(no active workers)"
                else
                    while IFS= read -r wname; do
                        STATUS=$(bash -c "source \"$SPAWN\" && worker_status \"\$1\" \"\$2\"" \
                            _ "$wname" "$PROJECT" 2>/dev/null || echo "unknown")
                        PCT=$(context_pct "$wname" "$PROJECT")
                        echo "${wname}: ${STATUS} ${PCT}"
                    done <<< "$NAMES"
                fi
            else
                # All from registry
                if [ ! -d "$REGISTRY_DIR" ] || [ -z "$(ls -A "$REGISTRY_DIR" 2>/dev/null)" ]; then
                    echo "(no active workers)"
                else
                    for _f in "$REGISTRY_DIR"/*; do
                        [ -f "$_f" ] || continue
                        _wname=$(basename "$_f")
                        _proj=$(cat "$_f")
                        _status=$(bash -c "source \"$SPAWN\" && worker_status \"\$1\" \"\$2\"" \
                            _ "$_wname" "$_proj" 2>/dev/null || echo "unknown")
                        _pct=$(context_pct "$_wname" "$_proj")
                        echo "${_wname}: ${_status} ${_pct}"
                    done
                fi
            fi
        else
            [ $# -lt 1 ] && { echo "worker-cli status: need <name> [project_path]" >&2; exit 2; }
            NAME="$1"
            OVERRIDE="${2:-}"
            PROJECT=$(resolve_worker_project "$NAME" "$OVERRIDE")
            STATUS=$(bash -c "source \"$SPAWN\" && worker_status \"\$1\" \"\$2\"" \
                _ "$NAME" "$PROJECT" 2>/dev/null || echo "unknown")
            PCT=$(context_pct "$NAME" "$PROJECT")
            echo "${STATUS} ${PCT}"
        fi
        ;;
    capture)
        [ $# -lt 1 ] && { echo "worker-cli capture: need <name> [project_path]" >&2; exit 2; }
        NAME="$1"
        OVERRIDE="${2:-}"
        PROJECT=$(resolve_worker_project "$NAME" "$OVERRIDE")
        bash -c "source \"$SPAWN\" && worker_capture \"\$1\" \"\" \"\$2\"" \
            _ "$NAME" "$PROJECT"
        ;;
    response)
        [ $# -lt 1 ] && { echo "worker-cli response: need <name> [count] [project_path]" >&2; exit 2; }
        NAME="$1"
        # Position 2: integer => count of last N assistant turns; else => project_path override
        COUNT=1
        OVERRIDE=""
        if [ -n "${2:-}" ]; then
            if [[ "$2" =~ ^[0-9]+$ ]]; then
                COUNT="$2"
                OVERRIDE="${3:-}"
            else
                OVERRIDE="$2"
            fi
        fi
        PROJECT=$(resolve_worker_project "$NAME" "$OVERRIDE")
        WORKTREE="$PROJECT/.claude/worktrees/$NAME"
        if [ ! -d "$WORKTREE" ]; then
            echo "worker-cli response: no worktree for $NAME at $WORKTREE" >&2
            exit 2
        fi
        PROJECTS_DIR="$HOME/.claude/projects"
        if [ ! -d "$PROJECTS_DIR" ]; then
            echo "worker-cli response: ~/.claude/projects not found" >&2
            exit 3
        fi
        ENCODED_DIR="$PROJECTS_DIR/$(encode_worktree_path "$WORKTREE")"
        JSONL=$(ls -t "$ENCODED_DIR"/*.jsonl 2>/dev/null | head -1)
        if [ -z "$JSONL" ]; then
            echo "worker-cli response: no session JSONL found for $NAME at $ENCODED_DIR" >&2
            exit 4
        fi
        TEXT=$(jq -rs --argjson n "$COUNT" '[.[] | select(.type == "assistant" and (.message.content // [] | map(select(.type == "text")) | length > 0))] | if length == 0 then "" else (.[-($n):] | length as $L | to_entries | map("=== msg \(.key + 1)/\($L) ===\n" + (.value.message.content | map(select(.type == "text")) | map(.text) | join("\n\n"))) | join("\n\n")) end' "$JSONL" 2>/dev/null || true)
        if [ -z "$TEXT" ]; then
            echo "worker-cli response: no assistant text message found in $JSONL" >&2
            exit 5
        fi
        CHARS=${#TEXT}
        echo "=== response from $NAME (last $COUNT, $CHARS chars) ==="
        echo "$TEXT"
        ;;
    merge)
        [ $# -lt 1 ] && { echo "worker-cli merge: need <name> [project_path]" >&2; exit 2; }
        NAME="$1"
        OVERRIDE="${2:-}"
        PROJECT=$(resolve_worker_project "$NAME" "$OVERRIDE")
        CURRENT=$(git -C "$PROJECT" branch --show-current)
        echo "=== Commits on branch $NAME not in $CURRENT ==="
        git -C "$PROJECT" log "$CURRENT".."$NAME" --oneline -- || true
        echo
        echo "=== Merging $NAME into $CURRENT ==="
        git -C "$PROJECT" merge "$NAME" --no-ff -m "merge: worker $NAME"
        ;;
    kill)
        [ $# -lt 1 ] && { echo "worker-cli kill: need <name> [project_path]" >&2; exit 2; }
        NAME="$1"
        OVERRIDE="${2:-}"
        PROJECT=$(resolve_worker_project "$NAME" "$OVERRIDE")
        SESSION="worker-$(basename "$PROJECT")-$NAME"
        echo "Killing worker: $SESSION"
        tmux kill-session -t "$SESSION" 2>/dev/null && echo "  tmux session: killed" || echo "  tmux session: not found"
        git -C "$PROJECT" worktree remove --force ".claude/worktrees/$NAME" 2>/dev/null && echo "  worktree: removed" || echo "  worktree: not found"
        git -C "$PROJECT" branch -D "$NAME" 2>/dev/null && echo "  branch: deleted" || echo "  branch: not found"
        registry_delete "$NAME"
        echo "  registry: removed"
        ;;
    send)
        [ $# -lt 2 ] && { echo "worker-cli send: need <name> <message> [project_path]" >&2; exit 2; }
        NAME="$1"
        MESSAGE="$2"
        OVERRIDE="${3:-}"
        PROJECT=$(resolve_worker_project "$NAME" "$OVERRIDE")
        _WORKER_MSG="$MESSAGE" bash -c 'source "$1" && worker_send "$2" "$_WORKER_MSG" "$3"' \
            _ "$SPAWN" "$NAME" "$PROJECT"
        ;;
    spawn)
        [ $# -lt 3 ] && { echo "worker-cli spawn: need <name> <prompt_file> <project_path> [model] [--no-worktree]" >&2; exit 2; }
        NAME="$1"
        PROMPT_FILE="$2"; [[ "$PROMPT_FILE" != /* ]] && PROMPT_FILE="$(pwd)/$PROMPT_FILE"
        PROJECT=$(resolve_project_path "$3")
        MODEL="${4:-sonnet}"
        WORKTREE_FLAG=""
        [ "${5:-}" = "--no-worktree" ] && WORKTREE_FLAG="--no-worktree"
        cd "$PLUGIN" && python3 -m src.spawn.spawn "$NAME" "$PROMPT_FILE" "$PROJECT" "$MODEL" $WORKTREE_FLAG
        registry_write "$NAME" "$PROJECT"
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        echo "worker-cli: unknown subcommand '$CMD'" >&2
        usage >&2
        exit 2
        ;;
esac
